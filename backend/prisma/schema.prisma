generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["auth", "public"]
}

enum role_type {
  entrepreneur
  investisseur
  prestataire
  formateur
  administrateur

  @@schema("auth")
}

enum statut_compte {
  en_attente
  actif
  suspendu
  supprime

  @@schema("auth")
}

model utilisateurs {
  id              String        @id @default(uuid()) @db.Uuid
  nom_complet     String        @db.VarChar(150)
  email           String        @unique @db.VarChar(255)
  mot_de_passe    String
  telephone       String?       @db.VarChar(20)
  avatar_url      String?
  role            role_type
  statut          statut_compte @default(en_attente)
  langue          String        @default("fr") @db.Char(2)
  ville           String?       @db.VarChar(100)
  region          String?       @db.VarChar(100)
  is_verified     Boolean       @default(false)
  two_fa_secret   String?
  created_at      DateTime      @default(now()) @db.Timestamptz(6)
  updated_at      DateTime      @default(now()) @db.Timestamptz(6)
  deleted_at      DateTime?     @db.Timestamptz(6)
  trust_score     Float         @default(0.0)
  
  investisseur_profile investisseur_profiles?
  prestataire_profile  prestataire_profiles?
  projets         projets[]
  investissements investissements[]
  messages_envoyes messages[] @relation("MessagesEnvoyes")
  messages_recus   messages[] @relation("MessagesRecus")
  
  factures        factures[]
  depenses        depenses[]
  services        services_b2b[]
  commandes_passees commandes_b2b[]
  avis_donnes     avis_marketplace[] @relation("AvisDonneur")
  
  // EdTech Relations
  cours_crees     cours[]
  inscriptions    inscriptions_cours[]
  progressions    progression_lecons[]
  certificats     certificats[]
  
  business_plans  business_plans[]
  crm_deals       crm_deals[]
  rappels_fiscaux rappels_fiscaux[]
  forum_posts     forum_posts[]
  forum_replies   forum_replies[]
  
  // Collaborative Project Management
  projects_owned  projects_execution[]
  project_members project_members[]
  assigned_tasks  tasks[] @relation("TaskAssignee")
  task_comments   task_comments[]
  project_messages project_messages[]

  @@map("utilisateurs")
  @@schema("auth")
}

// --- EDTECH MODULE MODELS ---

model cours {
  id              String   @id @default(uuid()) @db.Uuid
  formateur_id    String   @db.Uuid
  titre           String   @db.VarChar(255)
  description     String   @db.Text
  image_url       String?  @db.Text
  categorie       String   @db.VarChar(100) // Fiscalité, Marketing, etc.
  niveau          String   @default("debutant") @db.VarChar(50)
  prix            Float    @default(0.0)
  duree_totale    Int      @default(0) // en minutes
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)

  formateur       utilisateurs @relation(fields: [formateur_id], references: [id], onDelete: Cascade)
  chapitres       chapitres[]
  inscriptions    inscriptions_cours[]
  certificats     certificats[]

  @@map("cours")
  @@schema("public")
}

model chapitres {
  id              String   @id @default(uuid()) @db.Uuid
  cours_id        String   @db.Uuid
  titre           String   @db.VarChar(255)
  ordre           Int      @default(1)

  cours           cours    @relation(fields: [cours_id], references: [id], onDelete: Cascade)
  lecons          lecons[]

  @@map("chapitres")
  @@schema("public")
}

model lecons {
  id              String   @id @default(uuid()) @db.Uuid
  chapitre_id     String   @db.Uuid
  titre           String   @db.VarChar(255)
  type            String   @default("video") @db.VarChar(50) // video, podcast, infographie, quiz
  contenu_url     String?  @db.Text
  description     String?  @db.Text
  duree           Int      @default(5)
  ordre           Int      @default(1)

  chapitre        chapitres @relation(fields: [chapitre_id], references: [id], onDelete: Cascade)
  progressions    progression_lecons[]
  quiz_questions  quiz_questions[]

  @@map("lecons")
  @@schema("public")
}

model quiz_questions {
  id              String   @id @default(uuid()) @db.Uuid
  lecon_id        String   @db.Uuid
  question        String   @db.Text
  options         Json     // Array of options
  reponse_index   Int      // Index of the correct answer

  lecon           lecons   @relation(fields: [lecon_id], references: [id], onDelete: Cascade)

  @@map("quiz_questions")
  @@schema("public")
}

model inscriptions_cours {
  id              String   @id @default(uuid()) @db.Uuid
  cours_id        String   @db.Uuid
  utilisateur_id  String   @db.Uuid
  date_inscrip    DateTime @default(now()) @db.Timestamptz(6)
  termine         Boolean  @default(false)

  cours           cours        @relation(fields: [cours_id], references: [id], onDelete: Cascade)
  utilisateur     utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)

  @@unique([cours_id, utilisateur_id])
  @@map("inscriptions_cours")
  @@schema("public")
}

model progression_lecons {
  id              String   @id @default(uuid()) @db.Uuid
  utilisateur_id  String   @db.Uuid
  lecon_id        String   @db.Uuid
  complete        Boolean  @default(false)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)

  utilisateur     utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)
  lecon           lecons       @relation(fields: [lecon_id], references: [id], onDelete: Cascade)

  @@unique([utilisateur_id, lecon_id])
  @@map("progression_lecons")
  @@schema("public")
}

model certificats {
  id              String   @id @default(uuid()) @db.Uuid
  cours_id        String   @db.Uuid
  utilisateur_id  String   @db.Uuid
  code_verif      String   @unique @db.VarChar(50)
  pdf_url         String?  @db.Text
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  cours           cours        @relation(fields: [cours_id], references: [id], onDelete: Cascade)
  utilisateur     utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)

  @@map("certificats")
  @@schema("public")
}

// --- REST OF THE PREVIOUS SCHEMA MODELS ---

model projects_execution {
  id                String   @id @default(uuid()) @db.Uuid
  owner_id          String   @db.Uuid
  nom               String   @db.VarChar(255)
  description       String?  @db.Text
  date_debut        DateTime @db.Timestamptz(6)
  date_fin          DateTime? @db.Timestamptz(6)
  budget_initial    Float    @default(0.0)
  statut            String   @default("actif") @db.VarChar(50) 
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)

  owner             utilisateurs @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  members           project_members[]
  tasks             tasks[]
  expenses          project_execution_expenses[]
  messages          project_messages[]

  @@map("projects_execution")
  @@schema("public")
}

model project_messages {
  id                String   @id @default(uuid()) @db.Uuid
  project_id        String   @db.Uuid
  expediteur_id     String   @db.Uuid
  contenu           String   @db.Text
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  project           projects_execution @relation(fields: [project_id], references: [id], onDelete: Cascade)
  expediteur        utilisateurs @relation(fields: [expediteur_id], references: [id], onDelete: Cascade)

  @@map("project_messages")
  @@schema("public")
}

model project_members {
  id                String   @id @default(uuid()) @db.Uuid
  project_id        String   @db.Uuid
  utilisateur_id    String   @db.Uuid
  role              String   @default("membre") @db.VarChar(50) 
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  project           projects_execution @relation(fields: [project_id], references: [id], onDelete: Cascade)
  utilisateur       utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)

  @@unique([project_id, utilisateur_id])
  @@map("project_members")
  @@schema("public")
}

model tasks {
  id                String   @id @default(uuid()) @db.Uuid
  project_id        String   @db.Uuid
  assignee_id       String?  @db.Uuid
  titre             String   @db.VarChar(255)
  description       String?  @db.Text
  priorite          String   @default("moyenne") @db.VarChar(20) 
  statut            String   @default("todo") @db.VarChar(20) 
  date_limite       DateTime? @db.Timestamptz(6)
  tags              String[]
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)

  project           projects_execution @relation(fields: [project_id], references: [id], onDelete: Cascade)
  assignee          utilisateurs? @relation("TaskAssignee", fields: [assignee_id], references: [id], onDelete: SetNull)
  comments          task_comments[]
  attachments       task_attachments[]

  @@map("tasks")
  @@schema("public")
}

model task_comments {
  id                String   @id @default(uuid()) @db.Uuid
  task_id           String   @db.Uuid
  utilisateur_id    String   @db.Uuid
  contenu           String   @db.Text
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  task              tasks        @relation(fields: [task_id], references: [id], onDelete: Cascade)
  utilisateur       utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)

  @@map("task_comments")
  @@schema("public")
}

model task_attachments {
  id                String   @id @default(uuid()) @db.Uuid
  task_id           String   @db.Uuid
  nom_fichier       String   @db.VarChar(255)
  url               String   @db.Text
  type_mime         String?  @db.VarChar(100)
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  task              tasks @relation(fields: [task_id], references: [id], onDelete: Cascade)

  @@map("task_attachments")
  @@schema("public")
}

model project_execution_expenses {
  id                String   @id @default(uuid()) @db.Uuid
  project_id        String   @db.Uuid
  titre             String   @db.VarChar(255)
  montant           Float
  categorie         String   @db.VarChar(100)
  date_depense      DateTime @default(now()) @db.Timestamptz(6)

  project           projects_execution @relation(fields: [project_id], references: [id], onDelete: Cascade)

  @@map("project_execution_expenses")
  @@schema("public")
}

model prestataire_profiles {
  id                String   @id @default(uuid()) @db.Uuid
  utilisateur_id    String   @unique @db.Uuid
  bio               String?  @db.Text
  competences       String[]
  tarif_heure       Float?
  disponible        Boolean  @default(true)
  score_reputation  Float    @default(0.0)
  portfolio         Json?    
  verifie           Boolean  @default(false)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)

  utilisateur       utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)

  @@map("prestataire_profiles")
  @@schema("public")
}

model services_b2b {
  id                String   @id @default(uuid()) @db.Uuid
  prestataire_id    String   @db.Uuid
  titre             String   @db.VarChar(255)
  description       String   @db.Text
  categorie         String   @db.VarChar(100)
  prix_basique      Float    @default(0)
  prix_standard     Float?
  prix_premium      Float?
  delai_livraison   Int      @default(1)
  tags              String[]
  actif             Boolean  @default(true)
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  prestataire       utilisateurs @relation(fields: [prestataire_id], references: [id], onDelete: Cascade)
  commandes         commandes_b2b[]

  @@map("services_b2b")
  @@schema("public")
}

model commandes_b2b {
  id                String   @id @default(uuid()) @db.Uuid
  service_id        String   @db.Uuid
  client_id         String   @db.Uuid
  prestataire_id    String   @db.Uuid
  montant_total     Float
  statut            String   @default("EN_ATTENTE") @db.VarChar(50)
  brief             String?  @db.Text
  fichiers_joints   String[]
  date_livraison_est DateTime? @db.Timestamptz(6)
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  service           services_b2b @relation(fields: [service_id], references: [id], onDelete: Cascade)
  client            utilisateurs @relation(fields: [client_id], references: [id], onDelete: Cascade)
  escrow            escrow_transactions?
  avis              avis_marketplace?

  @@map("commandes_b2b")
  @@schema("public")
}

model escrow_transactions {
  id                String   @id @default(uuid()) @db.Uuid
  commande_id       String   @unique @db.Uuid
  montant           Float
  statut_escrow     String   @default("BLOQUE") @db.VarChar(50)
  reference_paiement String? @db.VarChar(100)
  date_liberation   DateTime? @db.Timestamptz(6)
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  commande          commandes_b2b @relation(fields: [commande_id], references: [id], onDelete: Cascade)

  @@map("escrow_transactions")
  @@schema("public")
}

model avis_marketplace {
  id                String   @id @default(uuid()) @db.Uuid
  commande_id       String   @unique @db.Uuid
  donneur_id        String   @db.Uuid
  note              Int      
  commentaire       String?  @db.Text
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  commande          commandes_b2b @relation(fields: [commande_id], references: [id], onDelete: Cascade)
  donneur           utilisateurs  @relation("AvisDonneur", fields: [donneur_id], references: [id], onDelete: Cascade)

  @@map("avis_marketplace")
  @@schema("public")
}

model projets {
  id                String   @id @default(uuid()) @db.Uuid
  entrepreneur_id   String   @db.Uuid
  nom               String   @db.VarChar(255)
  description       String
  secteur           String   @db.VarChar(150)
  ville             String?  @db.VarChar(100)
  region            String?  @db.VarChar(100)
  budget_recherche  Float
  stade_evolution   String   @db.VarChar(50)
  trust_score       Float    @default(0.0)
  description_detaillee String?
  pdf_url           String?
  video_url         String?
  equipe_taille     Int      @default(1)
  equipe_profils    String?
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)

  entrepreneur      utilisateurs @relation(fields: [entrepreneur_id], references: [id], onDelete: Cascade)
  investissements   investissements[]
  
  @@map("projets")
  @@schema("public")
}

model investissements {
  id              String   @id @default(uuid()) @db.Uuid
  projet_id       String   @db.Uuid
  investisseur_id String   @db.Uuid
  montant         Float
  date_invest     DateTime @default(now()) @db.Timestamptz(6)
  statut          String   @default("en_attente") @db.VarChar(50)

  projet          projets       @relation(fields: [projet_id], references: [id], onDelete: Cascade)
  investisseur    utilisateurs  @relation(fields: [investisseur_id], references: [id], onDelete: Cascade)

  @@map("investissements")
  @@schema("public")
}

model investisseur_profiles {
  id                String   @id @default(uuid()) @db.Uuid
  utilisateur_id    String   @unique @db.Uuid
  secteurs_interet  String[]
  ticket_min        Float
  ticket_max        Float
  regions_pref      String[]
  type_invest       String   @db.VarChar(100)
  credibility_score Float    @default(0.0)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)

  utilisateur       utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)

  @@map("investisseur_profiles")
  @@schema("public")
}

model messages {
  id              String   @id @default(uuid()) @db.Uuid
  expediteur_id   String   @db.Uuid
  destinataire_id String   @db.Uuid
  contenu         String
  lu              Boolean  @default(false)
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  expediteur      utilisateurs @relation("MessagesEnvoyes", fields: [expediteur_id], references: [id], onDelete: Cascade)
  destinataire    utilisateurs @relation("MessagesRecus", fields: [destinataire_id], references: [id], onDelete: Cascade)

  @@map("messages")
  @@schema("public")
}

model factures {
  id              String   @id @default(uuid()) @db.Uuid
  utilisateur_id  String   @db.Uuid
  numero_ref      String   @unique @db.VarChar(50)
  client_nom      String   @db.VarChar(150)
  client_ice      String?  @db.VarChar(50)
  client_adresse  String?  @db.Text
  total_ht        Float
  tva             Float
  total_ttc       Float
  statut          String   @default("en_attente") @db.VarChar(50)
  date_emission   DateTime @default(now()) @db.Timestamptz(6)
  date_echeance   DateTime @db.Timestamptz(6)

  utilisateur     utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)
  items           invoice_items[]

  @@map("factures")
  @@schema("public")
}

model invoice_items {
  id              String   @id @default(uuid()) @db.Uuid
  facture_id      String   @db.Uuid
  designation     String   @db.VarChar(255)
  quantite        Int
  prix_unitaire   Float
  tva_taux        Float    @default(20)
  total_ht        Float
  total_ttc       Float

  facture         factures @relation(fields: [facture_id], references: [id], onDelete: Cascade)

  @@map("invoice_items")
  @@schema("public")
}

model depenses {
  id              String   @id @default(uuid()) @db.Uuid
  utilisateur_id  String   @db.Uuid
  categorie       String   @db.VarChar(100)
  montant         Float
  description     String?
  justificatif_url String? @db.Text
  date_depense    DateTime @default(now()) @db.Timestamptz(6)

  utilisateur     utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)

  @@map("depenses")
  @@schema("public")
}

model rappels_fiscaux {
  id              String   @id @default(uuid()) @db.Uuid
  utilisateur_id  String   @db.Uuid
  type_taxe       String   @db.VarChar(50)
  date_limite     DateTime @db.Date
  montant_estime  Float?
  statut          String   @default("À venir") @db.VarChar(20)
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  utilisateur     utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)

  @@map("rappels_fiscaux")
  @@schema("public")
}

model business_plans {
  id                String   @id @default(uuid()) @db.Uuid
  utilisateur_id    String   @db.Uuid
  nom_projet        String   @db.VarChar(255)
  secteur           String   @db.VarChar(150)
  reponses_form     Json     
  statut            String   @default("brouillon") @db.VarChar(50)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @db.Timestamptz(6)

  utilisateur       utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)
  versions          business_plan_versions[]

  @@map("business_plans")
  @@schema("public")
}

model business_plan_versions {
  id                String   @id @default(uuid()) @db.Uuid
  plan_id           String   @db.Uuid
  contenu_json      Json     
  version_num       Int      @default(1)
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  plan              business_plans @relation(fields: [plan_id], references: [id], onDelete: Cascade)

  @@map("business_plan_versions")
  @@schema("public")
}

model crm_deals {
  id                  String   @id @default(uuid()) @db.Uuid
  utilisateur_id      String   @db.Uuid
  nom_entreprise      String   @db.VarChar(255)
  statut              String   @db.VarChar(50)
  montant_estime      Float    @default(0.0)
  derniere_interaction DateTime @default(now()) @db.Timestamptz(6)

  utilisateur         utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)

  @@map("crm_deals")
  @@schema("public")
}

model forum_posts {
  id              String   @id @default(uuid()) @db.Uuid
  utilisateur_id  String   @db.Uuid
  titre           String   @db.VarChar(255)
  contenu         String
  categorie       String   @db.VarChar(100)
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  utilisateur     utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)
  replies         forum_replies[]

  @@map("forum_posts")
  @@schema("public")
}

model forum_replies {
  id              String   @id @default(uuid()) @db.Uuid
  post_id         String   @db.Uuid
  utilisateur_id  String   @db.Uuid
  contenu         String
  created_at      DateTime @default(now()) @db.Timestamptz(6)

  post            forum_posts @relation(fields: [post_id], references: [id], onDelete: Cascade)
  utilisateur     utilisateurs @relation(fields: [utilisateur_id], references: [id], onDelete: Cascade)

  @@map("forum_replies")
  @@schema("public")
}
