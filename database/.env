# NexaMa — Variables d'environnement (.env)
# IMPORTANT : Ne jamais versionner ce fichier — ajouté dans .gitignore

# ─── PostgreSQL 16 ─────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=nexama_db
POSTGRES_USER=nexama_user
POSTGRES_PASSWORD=NexaMa_PG_2025!

# Connection string complète (Node.js / Prisma / Sequelize)
DATABASE_URL=postgresql://nexama_user:NexaMa_PG_2025!@localhost:5432/nexama_db

# ─── Redis 7 ───────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=NexaMa_Redis_2025!
REDIS_URL=redis://:NexaMa_Redis_2025!@localhost:6379/0

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=NexaMa_JWT_Ultra_Secret_2025_ChangeInProd!
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── APIs IA Gratuites ─────────────────────────────────────
GEMINI_API_KEY=YOUR_GOOGLE_GEMINI_API_KEY
GROQ_API_KEY=YOUR_GROQ_API_KEY
HUGGINGFACE_API_KEY=YOUR_HF_API_KEY
COHERE_API_KEY=YOUR_COHERE_API_KEY
OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY

# ─── Paiement ──────────────────────────────────────────────
CMI_MERCHANT_ID=YOUR_CMI_MERCHANT_ID
CMI_SECRET_KEY=YOUR_CMI_SECRET
PAYZONE_API_KEY=YOUR_PAYZONE_KEY

# ─── Auth OAuth ────────────────────────────────────────────
GOOGLE_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID
GOOGLE_CLIENT_SECRET=YOUR_GOOGLE_OAUTH_CLIENT_SECRET
LINKEDIN_CLIENT_ID=YOUR_LINKEDIN_CLIENT_ID
LINKEDIN_CLIENT_SECRET=YOUR_LINKEDIN_CLIENT_SECRET

# ─── Storage ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_AWS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET
AWS_BUCKET_NAME=nexama-storage
AWS_REGION=eu-west-1
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name

# ─── Notifications ──────────────────────────────────────────
SENDGRID_API_KEY=YOUR_SENDGRID_KEY
TWILIO_ACCOUNT_SID=YOUR_TWILIO_SID
TWILIO_AUTH_TOKEN=YOUR_TWILIO_TOKEN
TWILIO_PHONE_NUMBER=+1234567890

# ─── pgAdmin (dev only) ────────────────────────────────────
PGADMIN_EMAIL=admin@nexama.ma
PGADMIN_PASSWORD=NexaAdmin2025!

# ─── App ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000
APP_VERSION=1.2.0
